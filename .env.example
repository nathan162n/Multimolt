# Supabase — required
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Supabase service role — local dev / migrations ONLY, never shipped in app
SUPABASE_SERVICE_ROLE_KEY=

# OpenClaw Gateway — used when no URL was saved in Settings (Settings → General wins after you click Save)
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# Leave empty for mock gateway; set to the same token your OpenClaw gateway expects (see: openclaw config / doctor)
OPENCLAW_GATEWAY_TOKEN=

# LLM API Keys (also stored encrypted via safeStorage at runtime)
GEMINI_API_KEY=
